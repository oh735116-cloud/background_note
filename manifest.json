{
  "manifest_version": 3,
  "name": "Memo-Driven Highlighter",
  "version": "0.1.0",
  "description": "Save selected words with memos and use them as personal web highlights.",
  "permissions": ["storage", "contextMenus", "tabs", "sidePanel"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "Memo-Driven_Highlighter.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Memo Highlighter"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "icons": {
    "16": "icon/icon-16x16.png",
    "48": "icon/icon-48x48.png",
    "128": "icon/icon-128x128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["floating-widget.html", "floating-widget.css"],
      "matches": ["http://*/*", "https://*/*"]
    },
    {
      "resources": [
        "icon/icon-16x16.png",
        "icon/icon-32x32.png",
        "icon/icon-48x48.png",
        "icon/icon-128x128.png"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
