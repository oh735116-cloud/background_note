{
  "manifest_version": 3,
  "name": "Memo-Driven Highlighter",
  "version": "0.1.0",
  "description": "Save selected words with memos and use them as personal web highlights.",
  "permissions": ["storage", "contextMenus", "activeTab", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "Memo-Driven_Highlighter.js"
  },
  "action": {
    "default_title": "Memo Highlighter"
  }
}
