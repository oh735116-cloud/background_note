  "highlighting": {
    "strategy": "TreeWalker로 텍스트 노드만 탐색하고 키워드 일치 부분만 span.mdh-highlight로 감싸기",
    "doNotUse": "document.body.innerHTML.replace 또는 단순 String.replace 기반 전체 HTML 치환",
    "wrapper": {
      "tag": "span",
      "className": "mdh-highlight",
      "dataAttributes": ["data-keyword", "data-memo"]
    },
    "excludedElements": [
      "script",
      "style",
      "textarea",
      "input",
      "select",
      "button",
      "code",
      "pre",
      "noscript",
      ".mdh-highlight"
    ],
    "collisionPolicy": "키워드를 길이 기준 내림차순으로 정렬해 긴 표현을 먼저 처리",
